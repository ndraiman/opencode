---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro"
import CreateSession from "../../components/CreateSession.tsx"
import { fetchProviders } from "../../lib/local-session-utils"

const localApiUrl =
  import.meta.env.VITE_LOCAL_API_URL || "http://localhost:4096"

let providersData
let error = null

try {
  providersData = await fetchProviders(localApiUrl)
} catch (e) {
  error = e.message
}

if (error) {
  return new Response(null, {
    status: 500,
    statusText: error,
  })
}

// Create models object from providers data
const models = {}
if (providersData?.providers) {
  providersData.providers.forEach((provider) => {
    const modelIds = Object.keys(provider.models)
    if (modelIds.length > 0) {
      models[`${provider.id} ${modelIds[0]}`] = [provider.id, modelIds[0]]
    }
  })
}
---

<StarlightPage
  hasSidebar={false}
  frontmatter={{
    title: "New Session",
    pagefind: false,
    template: "splash",
    tableOfContents: false,
    head: [
      {
        tag: "meta",
        attrs: {
          name: "description",
          content: "opencode - Create New Project Session",
        },
      },
    ],
  }}
>
  <CreateSession apiUrl={localApiUrl} models={models} client:only="solid" />
</StarlightPage>

<style is:global>
  body > .page > .main-frame .main-pane > main > .content-panel:first-of-type {
    display: none;
  }
  body > .page > .main-frame .main-pane > main {
    padding: 0;
  }
  body
    > .page
    > .main-frame
    .main-pane
    > main
    > .content-panel
    + .content-panel {
    border-top: none !important;
    padding: 0;
  }
</style>
