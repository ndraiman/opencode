{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@opencode/orchestrator",
  "version": "0.1.0",
  "description": "OpenCode Orchestrator API for managing multiple OpenCode instances",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "opencode-orchestrator": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "bun test",
    "test:clean": "find /tmp -name '*opencode-test*' -o -name '*orchestrator-test*' 2>/dev/null | xargs rm -rf || true",
    "test:check": "bun test && echo 'Checking for leftovers...' && find /tmp -name '*opencode-test*' -o -name '*orchestrator-test*' 2>/dev/null | wc -l",
    "dev": "bun --watch src/index.ts",
    "start": "bun dist/index.js"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "latest",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "hono": "^4.0.0",
    "zod": "^3.22.0"
  },
  "keywords": [
    "opencode",
    "orchestrator",
    "api",
    "development",
    "project-management"
  ],
  "author": "OpenCode Team",
  "license": "MIT"
}